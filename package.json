    "keybindings": [
      {
        "command": "aiForge.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "aiForge.generateFromDesc",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g"
      },
      {
        "command": "aiForge.fixErrors",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f"
      },
      {
        "command": "aiForge.explainSelection",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorHasSelection"
      },
      {
        "command": "aiForge.gitCommitMessage",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "aiForge.submenu",
          "group": "aiforge@1",
          "when": "editorTextFocus"
        }
      ],
      "aiForge.submenu": [
        {
          "command": "aiForge.explainSelection",
          "when": "editorHasSelection",
          "group": "1_understand@1"
        },
        {
          "command": "aiForge.refactorSelection",
          "when": "editorHasSelection",
          "group": "1_understand@2"
        },
        {
          "command": "aiForge.fixErrors",
          "group": "2_fix@1"
        },
        {
          "command": "aiForge.addDocstrings",
          "group": "2_fix@2"
        },
        {
          "command": "aiForge.addTests",
          "group": "3_generate@1"
        },
        {
          "command": "aiForge.generateFromDesc",
          "group": "3_generate@2"
        },
        {
          "command": "aiForge.gitCommitMessage",
          "group": "4_git@1"
        },
        {
          "command": "aiForge.gitExplainDiff",
          "group": "4_git@2"
        }
      ],
      "scm/title": [
        {
          "command": "aiForge.gitCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "explorer/context": [
        {
          "command": "aiForge.applyToFolder",
          "when": "explorerResourceIsFolder",
          "group": "aiforge"
        }
      ]
    },
    "submenus": [
      {
        "id": "aiForge.submenu",
        "label": "AI Forge"
      }
    ],
    "configuration": {
      "title": "AI Forge",
      "properties": {
        "aiForge.provider": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "ollama",
            "anthropic",
            "openai",
            "huggingface",
            "offline"
          ],
          "enumDescriptions": [
            "Auto-detect: use Ollama if running, else offline AI",
            "Ollama \u2014 local LLM, private, free. Also works with LM Studio, llama.cpp, and Jan via ollamaHost",
            "Anthropic Claude \u2014 cloud, requires API key",
            "OpenAI / compatible \u2014 works with OpenAI, Groq, Mistral, Together AI, or any OpenAI-compatible endpoint",
            "Hugging Face Inference API \u2014 cloud, requires API key. Access thousands of open models",
            "Built-in offline AI \u2014 no LLM, pattern-based, instant"
          ],
          "description": "AI provider to use"
        },
        "aiForge.ollamaHost": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        },
        "aiForge.ollamaModel": {
          "type": "string",
          "default": "qwen2.5-coder:7b",
          "description": "Ollama model to use"
        },
        "aiForge.openaiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI-compatible base URL (Groq, Mistral, LM Studio, etc.)"
        },
        "aiForge.openaiModel": {
          "type": "string",
          "default": "gpt-4o",
          "description": "OpenAI model name"
        },
        "aiForge.anthropicModel": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Anthropic model to use (e.g., claude-sonnet-4-6, claude-opus-4-6)"
        },
        "aiForge.huggingfaceModel": {
          "type": "string",
          "default": "Qwen/Qwen2.5-Coder-32B-Instruct",
          "description": "Hugging Face model ID (e.g., Qwen/Qwen2.5-Coder-32B-Instruct, meta-llama/Llama-3.3-70B-Instruct, mistralai/Mistral-Small-24B-Instruct-2501)"
        },
        "aiForge.huggingfaceBaseUrl": {
          "type": "string",
          "default": "https://api-inference.huggingface.co",
          "description": "Hugging Face Inference API base URL (change for dedicated endpoints)"
        },
        "aiForge.codeLensEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show AI Forge hints above functions (Code Lens)"
        },
        "aiForge.includeErrorsInContext": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include current diagnostics/errors in AI context"
        },
        "aiForge.includeGitDiffInContext": {
          "type": "boolean",
          "default": false,
          "description": "Automatically include git diff in AI context"
        },
        "aiForge.maxContextFiles": {
          "type": "number",
          "default": 5,
          "description": "Max number of related files to include as context"
        },
        "aiForge.autoRunFix": {
          "type": "boolean",
          "default": false,
          "description": "Automatically attempt to fix errors after running a script"
        },
        "aiForge.contextBudgetChars": {
          "type": "number",
          "default": 24000,
          "description": "Total character budget shared across all context parts (active file, related files, git diff, plugin data). Increase for larger models, decrease for faster/cheaper ones."
        },
        "aiForge.disabledPlugins": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of plugin IDs to disable. E.g. [\"databricks\", \"dbt\"]. Disabled plugins are never activated even when detected."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0",
    "@vscode/test-electron": "^2.3.0",
    "mocha": "^10.2.0",
    "@types/mocha": "^10.0.0",
    "glob": "^10.3.0"
  },
  "dependencies": {}
}
