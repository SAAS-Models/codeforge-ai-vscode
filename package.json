{
  "name": "evolve-ai",
  "displayName": "Evolve AI",
  "description": "Context-aware AI coding assistant with 16 auto-detecting plugins. Works with Ollama (local/offline), Claude, OpenAI, and HuggingFace. Understands your project, errors, git state, and cloud platforms (AWS, GCP, Azure, Databricks).",
  "version": "1.0.0",
  "publisher": "codeforge-ai",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "license": "MIT",
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Data Science",
    "Other"
  ],
  "keywords": [
    "ai",
    "code assistant",
    "ollama",
    "anthropic",
    "openai",
    "copilot alternative",
    "databricks",
    "aws",
    "azure",
    "gcp",
    "terraform",
    "docker",
    "kubernetes",
    "dbt",
    "local llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/EvolveMinds/codeforge-ai-vscode"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-forge",
          "title": "AI Forge",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "ai-forge": [
        {
          "type": "webview",
          "id": "aiForge.chatPanel",
          "name": "AI Chat"
        }
      ]
    },
